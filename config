#in this case, the more generalized program 'edit_toggle_boolean_option' takes a boolean input(possibly shell expanded) and the name of an option to set
add_command toggle_line_numbers 'evaluate_commands %sh{edit_toggle_boolean_option $EDIT_OPT_SHOW_LINE_NUMBERS show_line_numbers}' 'toggles the display of buffer line numbers'
add_command toggle_status_bar 'evaluate_commands %sh{edit_toggle_boolean_option $EDIT_OPT_SHOW_STATUS_BAR show_status_bar}' 'toggles the display of the status bar'
add_command fail_toggle 'evaluate_commands %sh{edit_toggle_boolean_option idk show_line_numbers}' 'fail'
